function cleanupTrash(days){
  var isFullClear = Number(days) === 0;
  if(days === undefined || days === null){
    var input = prompt('清理多少天前的文件？输入 0 表示清空回收站。', '30');
    if(input === null) return;
    if(String(input).trim() === '') return;
    days = parseInt(input, 10);
  }
  if(isNaN(days) || days < 0){showToast('请输入有效的天数，0 表示清空回收站','info');return;}
  var tip = isFullClear
    ? '确定要清空整个回收站吗？\n此操作不可恢复！'
    : '确定要清理回收站中超过 ' + days + ' 天的文件吗？\n此操作不可恢复！';
  if(!confirm(tip))return;
  fetch('/admin/api/cleanup_trash', {method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({days: days})})
    .then(function(r){return r.json()}).then(function(d){
      if(d.success){
        var actionText = isFullClear ? '已清空回收站' : ('已清理 ' + days + ' 天前文件');
        showToast(actionText + '：' + d.deleted_count + ' 个文件，释放 ' + (d.freed_bytes/1024/1024).toFixed(2) + ' MB','success');
        loadTrashStatus();
      } else {
        showToast('清理失败','error');
      }
    }).catch(function(e){showToast('清理失败：'+e.message,'error')});
}

