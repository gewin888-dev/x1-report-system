<script>
var TITLES={stats:'数据统计',users:'用户管理',records:'报告管理',templates:'模板管理',standards:'标准数据库管理',monitor:'系统监控',logs:'操作日志',docs:'系统文档'};
var allRecords=[],allLogs=[],editingUser=null;
var currentPage=1,totalPages=1,searchTimer=null,logSearchTimer=null;
var DOMAIN_MAP={hospital:'医院',pharma:'制药',biosafety:'生物安全',food:'食品',electronics:'电子',veterinary:'兽药'};

var _monitorTimer=null;
function switchPanel(name,el){
  document.querySelectorAll('.panel').forEach(function(p){p.classList.remove('active')});
  document.querySelectorAll('.nav-item').forEach(function(n){n.classList.remove('active')});
  document.getElementById('panel-'+name).classList.add('active');
  if(el)el.classList.add('active');
  document.getElementById('pageTitle').textContent=TITLES[name];
  if(_monitorTimer){clearInterval(_monitorTimer);_monitorTimer=null;}
  if(name==='stats')loadStats();
  if(name==='users')loadUsers();
  if(name==='records'){currentPage=1;loadRecords(1);}
  if(name==='templates')loadTemplates();
  if(name==='standards')loadStandards();
  if(name==='monitor'){loadMonitor();_monitorTimer=setInterval(loadMonitor,30000);}
  if(name==='logs')initLogs();
}

function showToast(message,type){
  var toast=document.createElement('div');
  toast.className='toast '+(type||'info');
  toast.textContent=message;
  document.body.appendChild(toast);
  setTimeout(function(){toast.classList.add('show')},10);
  setTimeout(function(){toast.classList.remove('show');setTimeout(function(){toast.remove()},300)},3000);
}
function loadStats(){
  fetch('/admin/api/stats').then(function(r){return r.json()}).then(function(d){
    document.getElementById('st-exports').textContent = d.total_exports || 0;
    document.getElementById('st-drafts').textContent = d.total_records || 0;
    document.getElementById('st-today').textContent = d.today_actions || 0;
    document.getElementById('st-templates').textContent = '14';
    var h = '';
    Object.keys(d.by_operator||{}).forEach(function(k){
      h += '<tr><td>'+k+'</td><td>'+d.by_operator[k]+'</td></tr>';
    });
    document.getElementById('tb-operator').innerHTML = h || '<tr><td colspan="2" class="empty">暂无数据</td></tr>';
    h = '';
    Object.keys(d.by_domain||{}).forEach(function(k){
      h += '<tr><td>'+(DOMAIN_MAP[k]||k)+'</td><td>'+d.by_domain[k]+'</td></tr>';
    });
    document.getElementById('tb-domain').innerHTML = h || '<tr><td colspan="2" class="empty">暂无数据</td></tr>';
    h = '';
    var months = Object.keys(d.by_month||{}).sort().reverse();
    months.forEach(function(m){
      if(/^[0-9]{4}-[0-9]{2}$/.test(m)){
        h += '<tr><td>'+m+'</td><td>'+d.by_month[m]+'</td></tr>';
      }
    });
    document.getElementById('tb-monthly').innerHTML = h || '<tr><td colspan="2" class="empty">暂无数据</td></tr>';
  });
}

function loadUsers(){
  fetch('/admin/api/users').then(function(r){return r.json()}).then(function(list){
    var h='';
    list.forEach(function(u){
      var roleMap = {
        'admin': '<span class="tag tag-admin">管理员</span>',
        'supervisor': '<span class="tag tag-user">主管</span>',
        'inspector': '<span class="tag tag-user">检测员</span>'
      };
      var tag = roleMap[u.role] || '<span class="tag tag-user">检测员</span>';
      var acts='<button class="btn btn-sm" onclick="editUser(\''+u.username+'\')">编辑</button> ';
      if(u.username!=='admin')acts+='<button class="btn btn-sm btn-danger" onclick="deleteUser(\''+u.username+'\')">删除</button>';
      h+='<tr><td>'+u.username+'</td><td>'+(u.display_name||'')+'</td><td>'+tag+'</td><td>'+(u.department||'')+'</td><td>'+(u.created||'')+'</td><td>'+acts+'</td></tr>';
    });
    document.getElementById('tb-users').innerHTML=h||'<tr><td colspan="6" class="empty">暂无用户</td></tr>';
  });
}

function showUserModal(user){
  editingUser=user||null;
  document.getElementById('modalTitle').textContent=user?'编辑用户':'新增用户';
  document.getElementById('fm-username').value=user?user.username:'';
  document.getElementById('fm-username').disabled=!!user;
  document.getElementById('fm-display').value=user?user.display_name:'';
  document.getElementById('fm-role').value=user?user.role:'inspector';
  document.getElementById('fm-department').value=user?user.department:'';
  document.getElementById('fm-password').value='';
  document.getElementById('fm-pw-hint').textContent=user?'留空则不修改密码':'';
  document.getElementById('userModal').classList.add('show');
}
function closeUserModal(){document.getElementById('userModal').classList.remove('show');editingUser=null;}

function editUser(username){
  fetch('/admin/api/users').then(function(r){return r.json()}).then(function(list){
    var u=list.find(function(x){return x.username===username});
    if(u)showUserModal(u);
  });
}

function saveUser(){
  var un=document.getElementById('fm-username').value.trim();
  var dn=document.getElementById('fm-display').value.trim();
  var rl=document.getElementById('fm-role').value;
  var dept=document.getElementById('fm-department').value.trim();
  var pw=document.getElementById('fm-password').value;
  if(!un){showToast('请输入用户名','info');return;}
  if(!editingUser&&!pw){showToast('请输入密码','info');return;}
  var body={display_name:dn,role:rl,department:dept};
  if(pw)body.password=pw;
  var url,method;
  if(editingUser){url='/admin/api/users/'+editingUser.username;method='PUT';}
  else{url='/admin/api/users';method='POST';body.username=un;body.password=pw;}
  fetch(url,{method:method,headers:{'Content-Type':'application/json'},body:JSON.stringify(body)}).then(function(r){
    if(!r.ok)return r.json().then(function(d){throw new Error(d.error||'操作失败')});
    closeUserModal();loadUsers();
  }).catch(function(e){showToast(e.message,'error')});
}

function deleteUser(username){
  if(username==='admin'){showToast('不能删除admin用户','error');return;}
  if(!confirm('确定要删除用户 '+username+' 吗？'))return;
  fetch('/admin/api/users/'+username,{method:'DELETE'}).then(function(r){
    if(!r.ok)return r.json().then(function(d){throw new Error(d.error||'删除失败')});
    loadUsers();
  }).catch(function(e){showToast(e.message,'error')});
}

function debounceSearch(){
  clearTimeout(searchTimer);
  searchTimer=setTimeout(function(){loadRecords(1)},300);
}

function loadRecords(page){
  if(typeof page==='number')currentPage=page;
  var kw=(document.getElementById('record-search').value||'').trim();
  var domain=document.getElementById('record-domain').value;
  var type=document.getElementById('record-type').value;
  var params='?page='+currentPage+'&page_size=50';
  if(kw)params+='&keyword='+encodeURIComponent(kw);
  if(domain)params+='&domain='+encodeURIComponent(domain);
  if(type)params+='&type='+encodeURIComponent(type);
  fetch('/admin/api/records'+params).then(function(r){return r.json()}).then(function(d){
    var records=d.records||[];
    allRecords=records;
    currentPage=d.page||1;
    totalPages=d.total_pages||1;
    // 填充领域下拉框
    var domains=d.domains||[];
    var domainSel=document.getElementById('record-domain');
    var curDomainVal=domainSel.value;
    domainSel.innerHTML='<option value="">全部领域</option>';
    domains.forEach(function(k){
      domainSel.innerHTML+='<option value="'+k+'">'+(DOMAIN_MAP[k]||k)+'</option>';
    });
    domainSel.value=curDomainVal;
    // 渲染记录
    renderRecords(records);
    renderPagination(d.total||0,currentPage,totalPages);
    loadTrashStatus();
  });
}

function renderRecords(filtered){
  var h = '';
  filtered.forEach(function(r){
    var displayDate = r.detection_date || r.created || r.updated || '-';
    var statusTag = '';
    if(r.type === 'draft') statusTag = '<span class="tag" style="background:#fff7e6;color:#d48806;border:1px solid #ffd591;">草稿记录</span> ';
    if(r.type === 'export') statusTag = '<span class="tag" style="background:#f6ffed;color:#389e0d;border:1px solid #b7eb8f;">导出记录</span>';
    h += '<div class="record-item">';
    h += '<div class="record-check"><input type="checkbox" class="rec-check" value="'+r.id+'"></div>';
    h += '<div class="record-main">';
    h += '<div class="record-title">'+(r.project_name||'未命名项目')+' '+statusTag+'</div>';
    h += '<div class="record-meta">';
    h += '<span><strong>委托单位：</strong>'+(r.client_name||'-')+'</span>';
    h += '<span><strong>报告编号：</strong>'+(r.report_number||'-')+'</span>';
    h += '<span><strong>日期：</strong>'+displayDate+'</span>';
    h += '<span><strong>检测员：</strong>'+(r.operator||'-')+'</span>';
    h += '<span><strong>领域：</strong>'+(DOMAIN_MAP[r.domain]||r.domain||'-')+'</span>';
    h += '</div>';
    if(r.type === 'export'){
      var feishuStatusParts = [];
      if(r.feishu_report_status === 'success') feishuStatusParts.push('报告飞书✅');
      else if(r.feishu_report_status === 'failed') feishuStatusParts.push('报告飞书❌'+(r.feishu_report_error?('（'+r.feishu_report_error+'）'):''));
      if(r.feishu_export_status === 'success') feishuStatusParts.push('记录飞书✅');
      else if(r.feishu_export_status === 'failed') feishuStatusParts.push('记录飞书❌'+(r.feishu_export_error?('（'+r.feishu_export_error+'）'):''));
      if(feishuStatusParts.length){
        h += '<div class="record-meta" style="margin-top:4px;color:#595959"><span><strong>飞书状态：</strong>'+feishuStatusParts.join('； ')+'</span></div>';
      }
    }
    h += '</div>';
    h += '<div class="record-actions">';
    if(r.type === 'export'){
      // 找到文件引用
      var filledDoc = null, boundDoc = null, passboxDoc = null;
      if(r.files && r.files.length > 0){
        filledDoc = r.files.filter(function(f){return f.name.indexOf('.filled.') >= 0;})[0];
        boundDoc = r.files.filter(function(f){return f.name.indexOf('.bound.') >= 0;})[0];
        passboxDoc = r.files.filter(function(f){return !f.name.includes('.filled.') && !f.name.includes('.bound.') && f.name.endsWith('.docx');})[0];
      }
      var reportFile = filledDoc || boundDoc;
      // 检测报告按钮（飞书+本地都显示）
      if(r.feishu_report_url){
        h += '<a class="btn btn-sm" href="'+r.feishu_report_url+'" target="_blank" style="background:#52c41a;color:#fff;border-color:#52c41a">📊 飞书报告</a>';
      }
      if(reportFile){
        h += '<a class="btn btn-sm" href="/download/'+reportFile.name+'" target="_blank">💾 本地报告</a>';
      }
      if(!r.feishu_report_url && !reportFile){
        h += '<button class="btn btn-sm" disabled>无报告</button>';
      }
      // 原始记录按钮（飞书+本地都显示）
      if(r.feishu_export_url){
        h += '<a class="btn btn-sm" href="'+r.feishu_export_url+'" target="_blank" style="background:#fa8c16;color:#fff;border-color:#fa8c16">📊 飞书记录</a>';
      }
      if(passboxDoc){
        h += '<a class="btn btn-sm" href="/download/'+passboxDoc.name+'" target="_blank">💾 本地记录</a>';
      }
      if(!r.feishu_export_url && !passboxDoc){
        h += '<button class="btn btn-sm" disabled>无记录</button>';
      }
      // 在线预览按钮
      if(reportFile){
        h += '<button class="btn btn-sm" style="color:#1890ff;border-color:#1890ff" onclick="previewFile(\''+reportFile.name+'\')">' + String.fromCharCode(128065) + ' 预览报告</button>';
      }
      if(passboxDoc){
        h += '<button class="btn btn-sm" style="color:#722ed1;border-color:#722ed1" onclick="previewFile(\''+passboxDoc.name+'\')">' + String.fromCharCode(128065) + ' 预览记录</button>';
      }
    } else {
      h += '<button class="btn btn-sm" disabled>无报告</button>';
      h += '<button class="btn btn-sm" disabled>无记录</button>';
    }
      if(r.type === 'export'){
        h += '<button class="btn btn-sm" style="color:#722ed1;border-color:#722ed1" onclick="retryFeishuUpload(\''+r.id+'\')">↻ 重传飞书</button>';
      }
      h += '<button class="btn btn-sm btn-danger" onclick="deleteRecord(\''+r.id+'\')">删除</button></div></div>';
  });
  if(filtered.length === 0){h = '<div class="empty">暂无记录</div>';}
  document.getElementById('record-list').innerHTML = '<div class="record-list">'+h+'</div>';
}

function renderPagination(total,page,pages){
  if(pages<=1){document.getElementById('record-pagination').innerHTML='';return;}
  var h='<div class="pagination">';
  h+='<button '+(page<=1?'disabled':'')+' onclick="loadRecords('+(page-1)+')">上一页</button>';
  // Show page buttons
  var start=Math.max(1,page-2),end=Math.min(pages,page+2);
  if(start>1){h+='<button onclick="loadRecords(1)">1</button>';if(start>2)h+='<span class="page-info">…</span>';}
  for(var i=start;i<=end;i++){
    if(i===page){h+='<button style="background:#1890ff;color:#fff;border-color:#1890ff" disabled>'+i+'</button>';}
    else{h+='<button onclick="loadRecords('+i+')">'+i+'</button>';}
  }
  if(end<pages){if(end<pages-1)h+='<span class="page-info">…</span>';h+='<button onclick="loadRecords('+pages+')">'+pages+'</button>';}
  h+='<button '+(page>=pages?'disabled':'')+' onclick="loadRecords('+(page+1)+')">下一页</button>';
  h+='<span class="page-info">共 '+total+' 条</span>';
  h+='</div>';
  document.getElementById('record-pagination').innerHTML=h;
}

function toggleAllRecords(el){
  document.querySelectorAll('.rec-check').forEach(function(cb){cb.checked = el.checked});
}

function batchDeleteRecords(){
  var ids = Array.from(document.querySelectorAll('.rec-check:checked')).map(function(cb){return cb.value});
  if(ids.length===0){showToast('请先勾选要删除的记录','info');return}
  if(!confirm('确定要批量删除选中的 '+ids.length+' 条记录吗？'))return;
  fetch('/admin/api/records/batch_delete', {method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({record_ids: ids})})
    .then(function(r){return r.json()}).then(function(res){
      showToast('已删除 '+(res.deleted_count||0)+' 条记录','success');
      loadRecords(currentPage);
    }).catch(function(e){showToast('删除失败：'+e.message,'error')});
}

function deleteRecord(recordId){
  var record = allRecords.find(function(r){return r.id === recordId});
  var label = (record && record.project_name) || recordId;
  if(!confirm('确定要删除「'+label+'」吗？'))return;
  fetch('/admin/api/records/'+recordId, {method:'DELETE'})
    .then(function(r){return r.json()})
    .then(function(d){
      if(d.success){loadRecords(currentPage);}else{showToast('删除失败：'+(d.error||'未知错误'),'error');}
    }).catch(function(e){showToast('删除失败：'+e.message,'error')});
}

function retryFeishuUpload(recordId){
  if(!confirm('确定要重传该记录的飞书文件吗？')) return;
  fetch('/admin/api/records/'+recordId+'/retry_feishu', {method:'POST'})
    .then(function(r){return r.json()})
    .then(function(d){
      if(d.success){
        var msg = '飞书重传完成';
        if(d.report_success) msg += '｜报告✅'; else msg += '｜报告❌';
        if(d.export_success) msg += '｜记录✅'; else msg += '｜记录❌';
        showToast(msg, 'success');
        loadRecords(currentPage);
      }else{
