    }else{
      status='<span class="tag tag-user">✓ '+t.template_count+' 个文件</span>';
    }
    var domainTag='<span class="tag" style="background:#f0f5ff;color:#1890ff;border-color:#adc6ff">'+DOMAIN_NAMES[t.domain]+'</span>';
    html+='<tr><td>'+t.name+'</td><td>'+domainTag+'</td><td>'+status+'</td><td><button class="btn btn-sm" onclick="viewTemplate('+String.fromCharCode(39)+t.id+String.fromCharCode(39)+')">👁️ 预览</button></td><td><button class="btn btn-sm" onclick="showUploadModal('+String.fromCharCode(39)+t.id+String.fromCharCode(39)+','+String.fromCharCode(39)+t.name+String.fromCharCode(39)+')">⬆️ 上传</button></td></tr>';
