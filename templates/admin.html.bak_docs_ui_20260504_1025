function debounceLogSearch(){
  clearTimeout(logSearchTimer);
  logSearchTimer=setTimeout(function(){loadLogs()},300);
}

function loadLogs(){
  var month=document.getElementById('log-month').value;
  if(!month)return;
  var keyword=(document.getElementById('log-keyword').value||'').trim();
  var params='?month='+encodeURIComponent(month);
  if(keyword)params+='&keyword='+encodeURIComponent(keyword);
  fetch('/admin/api/logs'+params).then(function(r){return r.json()}).then(function(list){
    allLogs=list;
    var userSel=document.getElementById('log-user');
    var actSel=document.getElementById('log-action');
    var currentUser=userSel.value;
    var currentAction=actSel.value;
    var users={},actions={};
    list.forEach(function(l){if(l.user)users[l.user]=1;if(l.action)actions[l.action]=1});
    userSel.innerHTML='<option value="">全部用户</option>';
    Object.keys(users).forEach(function(k){userSel.innerHTML+='<option value="'+k+'">'+k+'</option>'});
    actSel.innerHTML='<option value="">全部操作</option>';
    Object.keys(actions).forEach(function(k){actSel.innerHTML+='<option value="'+k+'">'+k+'</option>'});
    if(currentUser && users[currentUser]) userSel.value=currentUser;
    if(currentAction && actions[currentAction]) actSel.value=currentAction;
    filterLogs();
  });
}

function filterLogs(){
  var u=document.getElementById('log-user').value;
  var a=document.getElementById('log-action').value;
  var filtered=allLogs.filter(function(l){
    if(u&&l.user!==u)return false;
    if(a&&l.action!==a)return false;
    return true;
  });
  var h='';
  filtered.forEach(function(l){
    h+='<tr><td>'+(l.time||'')+'</td><td>'+(l.user||'')+'</td><td>'+(l.action||'')+'</td><td>'+(l.target||'')+'</td><td>'+(l.detail||'')+'</td></tr>';
  });
  document.getElementById('tb-logs').innerHTML=h||'<tr><td colspan="5" class="empty">暂无日志</td></tr>';
}

function escapeHtml(s){
  return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

function colorizeStatus(text){
  return text
    .replace(/已通过/g,'<span style="display:inline-block;padding:2px 8px;border-radius:10px;background:#f6ffed;color:#389e0d;border:1px solid #b7eb8f;font-weight:600">已通过</span>')
    .replace(/待验证/g,'<span style="display:inline-block;padding:2px 8px;border-radius:10px;background:#fffbe6;color:#d48806;border:1px solid #ffe58f;font-weight:600">待验证</span>')
    .replace(/未验证/g,'<span style="display:inline-block;padding:2px 8px;border-radius:10px;background:#fffbe6;color:#d48806;border:1px solid #ffe58f;font-weight:600">未验证</span>')
    .replace(/有问题/g,'<span style="display:inline-block;padding:2px 8px;border-radius:10px;background:#fff2f0;color:#cf1322;border:1px solid #ffccc7;font-weight:600">有问题</span>')
    .replace(/高/g,'<span style="display:inline-block;padding:2px 8px;border-radius:10px;background:#fff1f0;color:#cf1322;border:1px solid #ffa39e;font-weight:600">高</span>')
    .replace(/中/g,'<span style="display:inline-block;padding:2px 8px;border-radius:10px;background:#fff7e6;color:#d46b08;border:1px solid #ffd591;font-weight:600">中</span>')
    .replace(/低/g,'<span style="display:inline-block;padding:2px 8px;border-radius:10px;background:#f6ffed;color:#389e0d;border:1px solid #b7eb8f;font-weight:600">低</span>');
}

function renderMarkdownLike(docName, text){
  if(docName !== 'TEST_LEDGER' && docName !== 'TEST_MATRIX') return null;
  var lines = String(text||'').split('\n');
  var html = '';
  var inTable = false;
  var tableIndex = 0;
  if(docName === 'TEST_LEDGER'){
    html += '<div style="display:flex;gap:12px;flex-wrap:wrap;margin-bottom:16px;padding:12px;background:#fff;border:1px solid #f0f0f0;border-radius:8px">'
      + '<div id="ledger-stat-pass" style="padding:10px 14px;border-radius:8px;background:#f6ffed;border:1px solid #b7eb8f;color:#389e0d;font-weight:700">已通过: 0</div>'
      + '<div id="ledger-stat-pending" style="padding:10px 14px;border-radius:8px;background:#fffbe6;border:1px solid #ffe58f;color:#d48806;font-weight:700">待处理: 0</div>'
      + '<div id="ledger-stat-high" style="padding:10px 14px;border-radius:8px;background:#fff1f0;border:1px solid #ffa39e;color:#cf1322;font-weight:700">高风险: 0</div>'
      + '<input id="ledger-search" oninput="filterLedgerTable()" placeholder="搜索对象 / 模板 / 问题编号..." style="min-width:260px;flex:1;padding:8px 10px;border:1px solid #d9d9d9;border-radius:6px">'
      + '<select id="ledger-status-filter" onchange="filterLedgerTable()" style="padding:6px 10px;border:1px solid #d9d9d9;border-radius:6px"><option value="">全部状态</option><option value="已通过">已通过</option><option value="待验证">待验证</option><option value="未验证">未验证</option><option value="有问题">有问题</option></select>'
      + '<select id="ledger-risk-filter" onchange="filterLedgerTable()" style="padding:6px 10px;border:1px solid #d9d9d9;border-radius:6px"><option value="">全部风险</option><option value="高">高</option><option value="中">中</option><option value="低">低</option></select>'
      + '<label style="display:flex;align-items:center;gap:6px;font-size:13px;color:#666"><input type="checkbox" id="ledger-pending-only" onchange="filterLedgerTable()"> 只看未完成项</label>'
      + '</div>';
  }
  lines.forEach(function(line){
    if(line.startsWith('# ')){
      if(inTable){ html += '</tbody></table>'; inTable=false; }
      html += '<h2 style="margin:8px 0 16px;font-size:22px">'+escapeHtml(line.slice(2))+'</h2>';
    } else if(line.startsWith('## ')){
      if(inTable){ html += '</tbody></table></div>'; inTable=false; }
      html += '<h3 style="margin:20px 0 12px;font-size:18px;color:#1677ff">'+escapeHtml(line.slice(3))+'</h3>';
    } else if(line.startsWith('> ')){
      if(inTable){ html += '</tbody></table></div>'; inTable=false; }
      html += '<div style="background:#f5f5f5;border-left:4px solid #d9d9d9;padding:10px 12px;margin:10px 0;color:#666">'+escapeHtml(line.slice(2))+'</div>';
    } else if(/^\|.*\|$/.test(line)){
      var cells = line.split('|').slice(1,-1).map(function(s){ return s.trim(); });
      var isSep = cells.every(function(c){ return /^-+$/.test(c.replace(/:/g,'')); });
      if(!inTable && !isSep){
        tableIndex++;
        html += '<div style="overflow:auto"><table class="ledger-table" data-table-index="'+tableIndex+'" style="width:max-content;min-width:100%;border-collapse:collapse;font-size:12px;background:#fff"><thead><tr>'+
          cells.map(function(c){ return '<th style="position:sticky;top:0;background:#fafafa;border:1px solid #eee;padding:8px 10px;white-space:nowrap">'+escapeHtml(c)+'</th>'; }).join('')+
          '</tr></thead><tbody>';
        inTable = true;
      } else if(inTable && !isSep){
        var status = cells[6] || '';
        var risk = cells[11] || '';
        html += '<tr class="ledger-row" data-status="'+escapeHtml(status)+'" data-risk="'+escapeHtml(risk)+'">' + cells.map(function(c){ return '<td style="border:1px solid #f0f0f0;padding:8px 10px;vertical-align:top;white-space:nowrap">'+colorizeStatus(escapeHtml(c))+'</td>'; }).join('') + '</tr>';
      }
    } else {
      if(inTable){ html += '</tbody></table></div>'; inTable=false; }
      if(line.trim()==='---') html += '<hr style="border:none;border-top:1px solid #eee;margin:18px 0">';
      else if(line.trim()) html += '<div style="margin:6px 0">'+escapeHtml(line)+'</div>';
    }
  });
  if(inTable) html += '</tbody></table></div>';
  return html;
}

function filterLedgerTable(){
  var status = (document.getElementById('ledger-status-filter')||{}).value || '';
  var risk = (document.getElementById('ledger-risk-filter')||{}).value || '';
  var search = ((document.getElementById('ledger-search')||{}).value || '').trim().toLowerCase();
  var pendingOnly = !!((document.getElementById('ledger-pending-only')||{}).checked);
  var passCount = 0, pendingCount = 0, highCount = 0;
  document.querySelectorAll('.ledger-row').forEach(function(row){
    var rowStatus = row.getAttribute('data-status') || '';
    var rowRisk = row.getAttribute('data-risk') || '';
    var rowText = (row.textContent || '').toLowerCase();
    var pending = rowStatus !== '已通过';
    var ok = (!status || rowStatus.indexOf(status)>=0) && (!risk || rowRisk.indexOf(risk)>=0) && (!pendingOnly || pending) && (!search || rowText.indexOf(search)>=0);
    row.style.display = ok ? '' : 'none';
    if(ok){
      if(rowStatus.indexOf('已通过')>=0) passCount++;
      else pendingCount++;
      if(rowRisk.indexOf('高')>=0) highCount++;
    }
  });
  var p=document.getElementById('ledger-stat-pass'); if(p) p.textContent='已通过: '+passCount;
  var pe=document.getElementById('ledger-stat-pending'); if(pe) pe.textContent='待处理: '+pendingCount;
  var h=document.getElementById('ledger-stat-high'); if(h) h.textContent='高风险: '+highCount;
}


function loadDoc(docName, evt){
  var btn=(evt && evt.target) ? evt.target : null;
  if(btn){
    var allBtns=btn.parentElement.querySelectorAll('.btn');
    allBtns.forEach(function(b){b.classList.remove('btn-primary');b.classList.add('btn')});
    btn.classList.add('btn-primary');
    btn.classList.remove('btn');
  }
  
  var content=document.getElementById('doc-content');
  content.textContent='加载中...';
  content.style.whiteSpace='pre-wrap';
  content.style.fontFamily='monospace';
  
  fetch('/admin/api/docs/'+docName).then(function(r){return r.json()}).then(function(d){
    if(d.error){content.textContent='错误: '+d.error;return;}
    var rendered = renderMarkdownLike(docName, d.content);
    if(rendered){
      content.style.whiteSpace='normal';
      content.style.fontFamily='-apple-system,BlinkMacSystemFont,"Segoe UI","PingFang SC",sans-serif';
      content.innerHTML = rendered;
      if(docName === 'TEST_LEDGER') setTimeout(filterLedgerTable, 0);
    }else{
      content.textContent=d.content;
    }
  }).catch(function(e){
    content.textContent='加载失败: '+e.message;
  });
}

loadStats();
</script>
