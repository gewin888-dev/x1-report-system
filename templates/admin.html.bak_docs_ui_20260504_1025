var ALL_STANDARDS=[];

function renderStandards(stds){
  var html='';
  stds.forEach(s=>{
    var domainTags=(s.domains||[]).map(d=>'<span class="tag tag-domain">'+d+'</span>').join('');
    var objTags=(s.objects||[]).map(o=>'<span class="tag">'+(OBJ_NAMES[o]||o)+'</span>').join('');
    html+='<tr><td><strong>'+s.code+'</strong></td><td style="font-size:12px;color:#555">'+(STD_NAMES[s.code]||'—')+'</td><td>'+(domainTags||'<span style="color:#999">—</span>')+'</td><td>'+objTags+'</td><td style="text-align:right"><button class="btn btn-sm" onclick="viewStandard(\''+s.code+'\')" >查看</button></td></tr>';
  });
  document.getElementById('tb-standards').innerHTML=html||'<tr><td colspan="5" class="empty">暂无匹配标准</td></tr>';
}

function filterStandards(){
  var kw=(document.getElementById('standards-search')||{}).value||'';
  kw=kw.trim().toLowerCase();
  if(!kw){renderStandards(ALL_STANDARDS);return;}
  var list=ALL_STANDARDS.filter(function(s){
    var code=(s.code||'').toLowerCase();
    var name=(STD_NAMES[s.code]||'').toLowerCase();
    var domains=(s.domains||[]).join(' ').toLowerCase();
    var objects=(s.objects||[]).map(function(o){return (OBJ_NAMES[o]||o);}).join(' ').toLowerCase();
    return code.indexOf(kw)!==-1 || name.indexOf(kw)!==-1 || domains.indexOf(kw)!==-1 || objects.indexOf(kw)!==-1;
  });
  renderStandards(list);
}

function loadStandards(){
  fetch('/admin/api/standards').then(r=>r.json()).then(d=>{
    var stds=d.standards||[];
    ALL_STANDARDS=stds;
    document.getElementById('cnt-std').textContent=stds.length;
    var objSet={};
    stds.forEach(s=>(s.objects||[]).forEach(o=>objSet[o]=1));
    document.getElementById('cnt-obj').textContent=Object.keys(objSet).length;
    filterStandards();
  });
}


