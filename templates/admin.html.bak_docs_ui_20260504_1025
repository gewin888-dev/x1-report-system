function filterTemplates(){
  var search=(document.getElementById('template-search')||{value:''}).value.toLowerCase();
  var domain=(document.getElementById('template-domain-filter')||{value:''}).value;
  var filtered=allTemplates.filter(function(t){
    var matchSearch=!search||(t.name+t.id).toLowerCase().includes(search);
    var matchDomain=!domain||t.domain===domain;
    return matchSearch&&matchDomain;
  });
  var html='';
  filtered.forEach(function(t){
    var status='';
    if(!t.exists){
      status='<span class="tag" style="background:#fff1f0;color:#cf1322;border-color:#ffa39e">⚠ 目录不存在</span>';
